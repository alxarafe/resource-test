<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars($title) ?></title>
    <!-- Bootstrap 5 & FontAwesome -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --bg-color: #f3f4f6;
            --card-bg: rgba(255, 255, 255, 0.7);
            --text-main: #1f2937;
            --text-muted: #6b7280;
        }
        body { 
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #e0e7ff 0%, #f3f4f6 100%);
            color: var(--text-main);
            min-height: 100vh;
        }
        /* Layout & Typography */
        h2 { font-weight: 700; letter-spacing: -0.5px; color: var(--primary) !important; }
        
        /* Cards & Glassmorphism */
        .card { 
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-radius: 16px; 
            border: 1px solid rgba(255, 255, 255, 0.5); 
            box-shadow: 0 10px 25px rgba(0,0,0,0.03);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.06);
        }
        .card-header { 
            background-color: transparent; 
            border-bottom: 1px solid rgba(0,0,0,0.05); 
            border-radius: 16px 16px 0 0 !important; 
            font-weight: 600;
            padding: 1rem 1.25rem;
            color: var(--text-main);
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
        }

        /* Nested Cards */
        .card .card {
            background: rgba(0, 0, 0, 0.015);
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
            border: 1px dashed rgba(0,0,0,0.1);
            backdrop-filter: none;
            -webkit-backdrop-filter: none;
        }
        .card .card-header {
            font-size: 0.75rem;
            color: var(--primary);
            border-bottom: 1px dashed rgba(0,0,0,0.05);
            padding: 0.75rem 1rem;
        }
        .card .card:hover {
            transform: translateY(-1px);
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.02), 0 4px 12px rgba(0,0,0,0.03);
            border: 1px solid rgba(79, 70, 229, 0.3);
        }

        /* Form Controls */
        .form-control, .form-select {
            border-radius: 8px;
            border: 1px solid #d1d5db;
            padding: 0.6rem 1rem;
            transition: all 0.2s;
            background-color: rgba(255, 255, 255, 0.9);
            font-family: 'Outfit', sans-serif;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.15);
            background-color: #fff;
        }
        .form-label {
            font-weight: 500;
            color: var(--text-muted);
            margin-bottom: 0.4rem;
        }
        .form-check-input:checked {
            background-color: var(--primary);
            border-color: var(--primary);
        }
        
        /* Tabs */
        .nav-tabs {
            border-bottom: 2px solid rgba(0,0,0,0.05);
            gap: 0.5rem;
        }
        .nav-tabs .nav-link { 
            font-weight: 500; 
            color: var(--text-muted); 
            border: none;
            border-radius: 8px 8px 0 0;
            padding: 0.75rem 1.25rem;
            transition: all 0.3s;
            position: relative;
        }
        .nav-tabs .nav-link::after {
            content: '';
            position: absolute;
            bottom: -2px; left: 0; width: 100%; height: 2px;
            background-color: var(--primary);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        .nav-tabs .nav-link:hover {
            color: var(--primary);
            background: rgba(79, 70, 229, 0.05);
        }
        .nav-tabs .nav-link.active { 
            color: var(--primary); 
            background: transparent; 
            font-weight: 600;
        }
        .nav-tabs .nav-link.active::after {
            transform: scaleX(1);
        }

        /* Buttons */
        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-hover));
            border: none;
            border-radius: 8px;
            padding: 0.6rem 1.5rem;
            font-weight: 600;
            box-shadow: 0 4px 10px rgba(79, 70, 229, 0.3);
            transition: all 0.3s;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(79, 70, 229, 0.4);
        }

        /* Alert */
        .alert-info {
            background: rgba(59, 130, 246, 0.1);
            color: #1e3a8a;
            border: 1px solid rgba(59, 130, 246, 0.2);
            backdrop-filter: blur(4px);
        }
        
        /* Animations */
        .tab-pane.active {
            animation: fadeIn 0.4s ease-out forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <h2 class="mb-4 text-primary"><i class="fas fa-layer-group"></i> <?= htmlspecialchars($title) ?></h2>
            
            <div class="alert alert-info border-0 shadow-sm rounded-3 mb-4">
                <i class="fas fa-info-circle me-2"></i> Esta vista ha sido generada con <strong>0 líneas de HTML</strong> en el controlador. 
                Todo proviene del array de configuración y se renderiza con <code>resource-html</code> recursivamente.
            </div>

            <!-- Form Rendering starts here -->
            <form action="<?= htmlspecialchars($config['action'] ?? '') ?>" method="<?= htmlspecialchars($config['method'] ?? 'POST') ?>">
                <?php 
                if (isset($config['body'])) {
                    echo $this->render('render_component', ['component' => $config['body']]);
                }
                ?>
                
                <div class="mt-4 text-end">
                    <?php foreach ($config['buttons'] ?? [] as $btn): ?>
                        <button type="<?= htmlspecialchars($btn['action']) ?>" name="<?= htmlspecialchars($btn['name']) ?>" class="btn btn-<?= htmlspecialchars($btn['type']) ?>">
                            <i class="<?= htmlspecialchars($btn['icon']) ?>"></i> <?= htmlspecialchars($btn['label']) ?>
                        </button>
                    <?php endforeach; ?>
                </div>
            </form>
            
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

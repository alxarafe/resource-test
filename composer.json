{
  "name": "alxarafe/resource-test",
  "description": "Showcase and testing project for alxarafe/resource-controller using PDO adapter.",
  "type": "project",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Rafael San José",
      "email": "rsanjose@alxarafe.com",
      "homepage": "https://alxarafe.es"
    }
  ],
  "require": {
    "php": "^8.2",
    "alxarafe/resource-controller": "0.2.0 as 0.1.99",
    "alxarafe/resource-pdo": "^0.1",
    "symfony/yaml": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Alxarafe\\ResourceTest\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Alxarafe\\ResourceTest\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
